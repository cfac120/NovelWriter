<Window x:Class="NovelWriter.App.Views.NewProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="创建新项目" Height="380" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="创建新项目" FontSize="20" FontWeight="Bold"
                   Foreground="#89B4FA" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="书名" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="TitleBox" Height="30"
                     Foreground="#CDD6F4" Background="#2A2A3C" BorderBrush="#45475A"
                     Padding="6" Margin="0,0,0,12"/>

            <TextBlock Text="题材" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>
            <ComboBox x:Name="GenreCombo" Height="30" Width="160" HorizontalAlignment="Left"
                      Background="#2A2A3C" Foreground="#CDD6F4" SelectedIndex="0" Margin="0,0,0,12">
                <ComboBoxItem Content="玄幻"/><ComboBoxItem Content="仙侠"/>
                <ComboBoxItem Content="都市"/><ComboBoxItem Content="科幻"/>
                <ComboBoxItem Content="历史"/><ComboBoxItem Content="奇幻"/>
                <ComboBoxItem Content="悬疑"/><ComboBoxItem Content="灵异"/>
            </ComboBox>

            <TextBlock Text="故事创意 (≤200字)" Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="IdeaBox" Height="80" AcceptsReturn="True"
                     TextWrapping="Wrap" MaxLength="200"
                     Foreground="#CDD6F4" Background="#2A2A3C" BorderBrush="#45475A"
                     Padding="6" VerticalScrollBarVisibility="Auto"/>
            <TextBlock x:Name="CharCount" Text="0/200" Foreground="#6C7086"
                       FontSize="10" HorizontalAlignment="Right" Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#F38BA8" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="取消" Click="Cancel_Click" IsCancel="True"
                    Foreground="#6C7086" Background="#313244" BorderThickness="0"
                    Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="创建并继续" Click="Create_Click" IsDefault="True"
                    Foreground="#A6E3A1" Background="#313244" BorderThickness="0"
                    Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
