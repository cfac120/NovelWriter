<Window x:Class="NovelWriter.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="350" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="设置" FontSize="18" FontWeight="Bold"
                   Foreground="#89B4FA" Margin="0,0,0,16"/>

        <TabControl Grid.Row="1" Background="#1E1E2E" BorderBrush="#313244">
            <TabItem Header="API 密钥" Background="#1E1E2E" Foreground="#CDD6F4">
                <StackPanel Margin="16">
                    <TextBlock Text="DeepSeek API Key" Foreground="#A6ADC8" Margin="0,0,0,4"/>
                    <TextBox x:Name="ApiKeyBox" Height="28"
                             Foreground="#CDD6F4" Background="#2A2A3C" BorderBrush="#45475A" Padding="6"
                             Margin="0,0,0,8"/>
                    <TextBlock Text="密钥存储在环境变量 DEEPSEEK_API_KEY 中。重启应用后需重新设置。"
                               Foreground="#6C7086" FontSize="10" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="模型" Background="#1E1E2E" Foreground="#CDD6F4">
                <StackPanel Margin="16">
                    <TextBlock Text="当前模型:" Foreground="#A6ADC8"/>
                    <TextBlock x:Name="ModelName" Text="DeepSeek V4 (deepseek-v4-pro)"
                               Foreground="#89B4FA" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Click="Cancel_Click"
                    Foreground="#6C7086" Background="#313244" BorderThickness="0"
                    Padding="12,6" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="保存" Click="Save_Click"
                    Foreground="#A6E3A1" Background="#313244" BorderThickness="0"
                    Padding="12,6" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
