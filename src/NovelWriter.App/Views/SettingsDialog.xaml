<Window x:Class="NovelWriter.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="480" Width="580"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="NovelWriter 设置" FontSize="18" FontWeight="Bold"
                   Foreground="#89B4FA" Margin="0,0,0,16"/>

        <TabControl Grid.Row="1" Background="#1E1E2E" BorderBrush="#313244">
            <TabItem Header="API 密钥" Background="#1E1E2E" Foreground="#CDD6F4">
                <StackPanel Margin="16">
                    <TextBlock Text="API 密钥配置" FontSize="14" FontWeight="SemiBold"
                               Foreground="#A6ADC8" Margin="0,0,0,12"/>

                    <TextBlock Text="DeepSeek API Key" Foreground="#6C7086" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="DeepSeekKey" Background="#2A2A3C"
                                     Foreground="#CDD6F4" BorderBrush="#45475A" Padding="6"/>
                        <Button Grid.Column="1" Content="测试" Click="TestDeepSeek_Click"
                                Foreground="#89B4FA" Background="#313244"
                                BorderThickness="0" Padding="8,4" Margin="8,0,0,0"/>
                    </Grid>

                    <TextBlock Text="Qwen (通义千问) API Key" Foreground="#6C7086" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="QwenKey" Background="#2A2A3C"
                                     Foreground="#CDD6F4" BorderBrush="#45475A" Padding="6"/>
                        <Button Grid.Column="1" Content="测试" Click="TestQwen_Click"
                                Foreground="#89B4FA" Background="#313244"
                                BorderThickness="0" Padding="8,4" Margin="8,0,0,0"/>
                    </Grid>

                    <TextBlock Text="Kimi (Moonshot) API Key" Foreground="#6C7086" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="KimiKey" Background="#2A2A3C"
                                     Foreground="#CDD6F4" BorderBrush="#45475A" Padding="6"/>
                        <Button Grid.Column="1" Content="测试" Click="TestKimi_Click"
                                Foreground="#89B4FA" Background="#313244"
                                BorderThickness="0" Padding="8,4" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="风格与插曲" Background="#1E1E2E" Foreground="#CDD6F4">
                <StackPanel Margin="16">
                    <TextBlock Text="风格库设置" FontSize="14" FontWeight="SemiBold"
                               Foreground="#A6ADC8" Margin="0,0,0,12"/>

                    <CheckBox x:Name="StyleEnabled" Content="启用随机风格注入"
                              Foreground="#CDD6F4" Margin="0,0,0,8"/>
                    <TextBlock Text="每章写作前随机选取风格档案，注入 System Prompt（约400 token）。卷内不重复。"
                               Foreground="#6C7086" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <TextBlock Text="插曲库设置" FontSize="14" FontWeight="SemiBold"
                               Foreground="#A6ADC8" Margin="0,0,0,12"/>

                    <CheckBox x:Name="InterludeEnabled" Content="启用随机插曲注入"
                              Foreground="#CDD6F4" Margin="0,0,0,8"/>
                    <TextBlock Text="每章写作前随机选取历史/轶事插曲，LLM 改编为闲笔后注入 User Message。卷内不重复。"
                               Foreground="#6C7086" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <Button Content="管理风格库..." Click="ManageStyles_Click"
                            Foreground="#89B4FA" Background="#313244"
                            BorderThickness="0" Padding="12,6" HorizontalAlignment="Left"
                            Margin="0,0,0,8"/>
                    <Button Content="管理插曲库..." Click="ManageInterludes_Click"
                            Foreground="#89B4FA" Background="#313244"
                            BorderThickness="0" Padding="12,6" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="评审" Background="#1E1E2E" Foreground="#CDD6F4">
                <StackPanel Margin="16">
                    <TextBlock Text="评审参数设置" FontSize="14" FontWeight="SemiBold"
                               Foreground="#A6ADC8" Margin="0,0,0,12"/>

                    <TextBlock Foreground="#6C7086" FontSize="11" Margin="0,0,0,4">
                        <Run Text="评审 Persona 数量:"/><Run Text="{Binding ElementName=PersonaCount, Path=Value}" Foreground="#89B4FA"/>
                    </TextBlock>
                    <Slider x:Name="PersonaCount" Minimum="2" Maximum="5" Value="4"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            Background="#313244" Margin="0,0,0,12"/>

                    <TextBlock Foreground="#6C7086" FontSize="11" Margin="0,0,0,4">
                        <Run Text="通过阈值:"/><Run Text="{Binding ElementName=PassThreshold, Path=Value, StringFormat='{}{0:F1}'}" Foreground="#89B4FA"/>
                    </TextBlock>
                    <Slider x:Name="PassThreshold" Minimum="5.0" Maximum="9.0" Value="7.0"
                            TickFrequency="0.5" IsSnapToTickEnabled="True"
                            Background="#313244" Margin="0,0,0,12"/>

                    <TextBlock Foreground="#6C7086" FontSize="11" Margin="0,0,0,4">
                        <Run Text="最大润色轮次:"/><Run Text="{Binding ElementName=MaxRevisions, Path=Value}" Foreground="#89B4FA"/>
                    </TextBlock>
                    <Slider x:Name="MaxRevisions" Minimum="1" Maximum="5" Value="3"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            Background="#313244" Margin="0,0,0,12"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Click="Cancel_Click"
                    Foreground="#6C7086" Background="#313244"
                    BorderThickness="0" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="保存" Click="Save_Click"
                    Foreground="#A6E3A1" Background="#313244"
                    BorderThickness="0" Padding="12,6" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
