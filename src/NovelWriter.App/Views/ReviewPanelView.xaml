<UserControl x:Class="NovelWriter.App.Views.ReviewPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <TextBlock Text="评审面板" FontSize="14" FontWeight="SemiBold"
                           Foreground="#A6ADC8" Margin="0,0,0,12"/>

                <Border Background="#2A2A3C" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="OverallScoreLabel" Text="--" FontSize="48" FontWeight="Bold"
                                   Foreground="#A6E3A1" HorizontalAlignment="Center"/>
                        <TextBlock Text="综合评分" Foreground="#6C7086" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="PersonaList" Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,0,0,6" Background="#2A2A3C">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding PersonaName}" Foreground="#89B4FA"
                                                   FontSize="12" FontWeight="SemiBold" Width="80"/>
                                        <TextBlock Text="{Binding Score, StringFormat='{}{0}/10'}"
                                                   Foreground="#A6E3A1" FontSize="12" Width="50"/>
                                        <TextBlock Text="{Binding Status}" Foreground="#6C7086" FontSize="11"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="8,4">
                                    <TextBlock Text="优点:" Foreground="#A6E3A1" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Strengths}" Foreground="#CDD6F4" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,2,0,8"/>
                                    <TextBlock Text="缺点:" Foreground="#F38BA8" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Weaknesses}" Foreground="#CDD6F4" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,2,0,8"/>
                                    <TextBlock Text="建议:" Foreground="#FAB387" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Suggestions}" Foreground="#CDD6F4" FontSize="11"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Expander Header="标记问题" IsExpanded="False"
                          Foreground="#F38BA8" Background="#2A2A3C" Margin="0,8,0,0">
                    <ItemsControl x:Name="FlaggedList" Margin="8,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#313244" Padding="6,4" Margin="0,0,0,3" CornerRadius="3">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Type}" Foreground="#F38BA8" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Detail}" Foreground="#A6ADC8" FontSize="10" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Button x:Name="AcceptBtn" Content="接受并定稿" Click="AcceptBtn_Click"
                            Foreground="#A6E3A1" Background="#313244"
                            BorderThickness="0" Padding="12,6" Margin="0,0,8,0"/>
                    <Button x:Name="ReviseBtn" Content="润色重写" Click="ReviseBtn_Click"
                            Foreground="#FAB387" Background="#313244"
                            BorderThickness="0" Padding="12,6" Margin="0,0,8,0"/>
                    <Button x:Name="SkipBtn" Content="跳过评审" Click="SkipBtn_Click"
                            Foreground="#6C7086" Background="#313244"
                            BorderThickness="0" Padding="12,6"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
