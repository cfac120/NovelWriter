<Window x:Class="NovelWriter.App.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovelWriter.App.ViewModels"
        xmlns:views="clr-namespace:NovelWriter.App.Views"
        Title="NovelWriter"
        Height="720" Width="1280"
        MinHeight="480" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.DataContext>
        <vm:ShellViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="#11111B" BorderBrush="#313244" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <Button Content="← 项目" Click="BackToProjects" Foreground="#A6ADC8"
                        Background="#2A2A3C" BorderThickness="0" Padding="8,2"/>
            </StackPanel>
        </Border>

        <!-- 主区域：三栏 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- 左栏 -->
            <Border Grid.Column="0" Background="#1A1A2E">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="NovelWriter" FontSize="18" FontWeight="Bold"
                                   Foreground="#89B4FA" Margin="0,8,0,16"/>
                        <ContentControl Content="{Binding ActiveView}">
                            <ContentControl.Resources>
                                <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
                                    <views:ProjectListView/>
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type vm:EditorViewModel}">
                                    <TextBlock Text="写作中" Foreground="#6C7086"/>
                                </DataTemplate>
                            </ContentControl.Resources>
                        </ContentControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 中栏 -->
            <Border Grid.Column="1" Background="#1E1E2E">
                <ContentControl Content="{Binding ActiveView}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:EditorViewModel}">
                            <views:EditorView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
                            <TextBlock Text="选择或创建项目开始写作"
                                       Foreground="#6C7086" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Border>

            <!-- 右栏 -->
            <Border Grid.Column="2" Background="#181825">
                <StackPanel Margin="12">
                    <TextBlock Text="章节列表" FontSize="14" Foreground="#A6ADC8" Margin="0,0,0,8"/>
                    <ContentControl Content="{Binding ActiveView}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vm:EditorViewModel}">
                                <ListBox ItemsSource="{Binding Chapters}"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#CDD6F4"/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
                                <TextBlock Text="暂无项目" Foreground="Gray"/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#11111B" Height="28">
            <Grid Margin="8,0">
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#A6ADC8"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"
                           Foreground="#6C7086">
                    <Run Text="字数:"/><Run Text="{Binding TotalWordCount}" Foreground="#89B4FA"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
