<Window x:Class="NovelWriter.App.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovelWriter.App.ViewModels"
        Title="NovelWriter" Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- 文件条目样式：悬停时显示淡蓝背景 -->
        <Style x:Key="FileListItem" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#10CDD6F4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 自定义 Expander 样式：淡选中 + 展开竖线 -->
        <Style x:Key="ArrowExpander" TargetType="Expander">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 展开竖线指示器 -->
                            <Border x:Name="ExpandLine" Grid.Column="0"
                                    Background="Transparent" Width="1" Margin="3,0,0,0"
                                    HorizontalAlignment="Left"
                                    Visibility="Collapsed"/>

                            <StackPanel Grid.Column="1">
                                <ToggleButton x:Name="ToggleBtn"
                                        IsChecked="{Binding IsExpanded, Mode=TwoWay,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                                        Padding="0">
                                    <ToggleButton.Resources>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border x:Name="Bd" Background="Transparent"
                                                                BorderThickness="0" Padding="0">
                                                            <ContentPresenter HorizontalAlignment="Left"
                                                                              VerticalAlignment="Center"
                                                                              Margin="0,3"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="#10CDD6F4"/>
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Bd" Property="Background"
                                                                        Value="#08CDD6F4"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Resources>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ArrowText" Text="▶" FontSize="9"
                                                   Foreground="#585B70" Width="12" TextAlignment="Center"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ContentPresenter
                                            Content="{Binding Header, RelativeSource={RelativeSource TemplatedParent}}"
                                            VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ContentPresenter x:Name="ContentSite" Visibility="Collapsed"
                                                  Margin="18,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ArrowText" Property="Text" Value="▼"/>
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ExpandLine" Property="Background" Value="#20CDD6F4"/>
                                <Setter TargetName="ExpandLine" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- === 菜单栏 === -->
        <Menu Grid.Row="0" Background="#11111B" Foreground="#A6ADC8" FontSize="12">
            <MenuItem Header="文件">
                <MenuItem Header="新建项目" Click="NewProject_Click" Foreground="#A6E3A1"/>
                <MenuItem Header="打开项目" Click="OpenProject_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="风格库">
                <MenuItem Header="从目录导入风格" Click="ImportStyles_Click"/>
                <MenuItem Header="管理风格库" Click="ManageStyles_Click"/>
            </MenuItem>
            <MenuItem Header="AI审查" IsEnabled="False"/>
            <MenuItem Header="发布" IsEnabled="False"/>
        </Menu>

        <!-- === 三栏主体 === -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 左栏：资源管理器 -->
            <Border Grid.Column="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- 小说内容 -->
                        <Expander x:Name="ContentExpander" IsExpanded="True" Margin="4,4,4,0">
                            <Expander.Header>
                                <TextBlock x:Name="ContentHeader" Text="NovelWriter" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#89B4FA"/>
                            </Expander.Header>
                            <StackPanel Margin="8,0">

                                <!-- 故事创意 -->
                                <Expander x:Name="IdeaExpander" IsExpanded="False" Margin="0,2,0,0"
                                          Style="{StaticResource ArrowExpander}">
                                    <Expander.Header>
                                        <TextBlock x:Name="IdeaFile" Text="故事创意" FontSize="12" Foreground="#CDD6F4"/>
                                    </Expander.Header>
                                    <ItemsControl x:Name="IdeaFileList" Margin="6,2,0,0" FontSize="11"
                                                  Background="Transparent" Foreground="#A6ADC8"
                                                  MouseLeftButtonUp="FileItem_Click">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FileListItem}">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#A6ADC8"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- 梗概 -->
                                <Expander x:Name="SynopsisExpander" IsExpanded="False" Margin="0,2,0,0"
                                          Style="{StaticResource ArrowExpander}">
                                    <Expander.Header>
                                        <TextBlock x:Name="SynopsisFile" Text="梗概" FontSize="12" Foreground="#CDD6F4"/>
                                    </Expander.Header>
                                    <ItemsControl x:Name="SynopsisFileList" Margin="6,2,0,0" FontSize="11"
                                                  Background="Transparent" Foreground="#A6ADC8"
                                                  MouseLeftButtonUp="FileItem_Click">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FileListItem}">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#A6ADC8"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- 大纲 -->
                                <Expander x:Name="OutlineExpander" IsExpanded="False" Margin="0,2,0,0"
                                          Style="{StaticResource ArrowExpander}">
                                    <Expander.Header>
                                        <TextBlock x:Name="OutlineFile" Text="大纲" FontSize="12" Foreground="#CDD6F4"/>
                                    </Expander.Header>
                                    <ItemsControl x:Name="OutlineFileList" Margin="6,2,0,0" FontSize="11"
                                                  Background="Transparent" Foreground="#A6ADC8"
                                                  MouseLeftButtonUp="FileItem_Click">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FileListItem}">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#A6ADC8"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- L3 记忆 -->
                                <Expander x:Name="L3Expander" IsExpanded="False" Margin="0,2,0,0"
                                          Style="{StaticResource ArrowExpander}">
                                    <Expander.Header>
                                        <TextBlock Text="L3 记忆" FontSize="12" Foreground="#CDD6F4"/>
                                    </Expander.Header>
                                    <ItemsControl x:Name="L3FileList" Margin="6,2,0,0" FontSize="11"
                                                  Background="Transparent" Foreground="#A6ADC8"
                                                  MouseLeftButtonUp="FileItem_Click">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FileListItem}">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#A6ADC8"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- L2 记忆 -->
                                <Expander x:Name="L2Expander" IsExpanded="False" Margin="0,2,0,0"
                                          Style="{StaticResource ArrowExpander}">
                                    <Expander.Header>
                                        <TextBlock Text="L2 记忆" FontSize="12" Foreground="#CDD6F4"/>
                                    </Expander.Header>
                                    <ItemsControl x:Name="L2FileList" Margin="6,2,0,0" FontSize="11"
                                                  Background="Transparent" Foreground="#A6ADC8"
                                                  MouseLeftButtonUp="FileItem_Click">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FileListItem}">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#A6ADC8"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- L1 记忆 -->
                                <Expander x:Name="L1Expander" IsExpanded="False" Margin="0,2,0,0"
                                          Style="{StaticResource ArrowExpander}">
                                    <Expander.Header>
                                        <TextBlock Text="L1 记忆" FontSize="12" Foreground="#CDD6F4"/>
                                    </Expander.Header>
                                    <ItemsControl x:Name="L1FileList" Margin="6,2,0,0" FontSize="11"
                                                  Background="Transparent" Foreground="#A6ADC8"
                                                  MouseLeftButtonUp="FileItem_Click">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FileListItem}">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#A6ADC8"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- 正文 -->
                                <Expander x:Name="ChapterExpander" IsExpanded="True" Margin="0,2,0,4"
                                          Style="{StaticResource ArrowExpander}">
                                    <Expander.Header>
                                        <TextBlock Text="正文" FontSize="12" Foreground="#CDD6F4"/>
                                    </Expander.Header>
                                    <TreeView x:Name="ChapterTree" Background="Transparent" BorderThickness="0"
                                              Foreground="#CDD6F4" FontSize="12" Margin="14,2,0,0"
                                              SelectedItemChanged="ChapterTreeSelected"/>
                                </Expander>

                            </StackPanel>
                        </Expander>

                        <!-- 插曲库 -->
                        <Expander Header="插曲库" IsExpanded="False" Margin="4,8,4,0">
                            <Expander.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="插曲库" FontSize="12" FontWeight="SemiBold" Foreground="#FAB387"/>
                                </DataTemplate>
                            </Expander.HeaderTemplate>
                            <TreeView x:Name="InterludeTree" Background="Transparent" BorderThickness="0"
                                      Foreground="#A6ADC8" FontSize="11" Height="150"
                                      SelectedItemChanged="InterludeSelected"/>
                        </Expander>

                        <!-- 风格库 -->
                        <Expander Header="风格库" IsExpanded="False" Margin="4,8,4,8">
                            <Expander.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="风格库" FontSize="12" FontWeight="SemiBold" Foreground="#A6E3A1"/>
                                </DataTemplate>
                            </Expander.HeaderTemplate>
                            <StackPanel Margin="4">
                                <Button Content="+ 导入风格" FontSize="11" Foreground="#89B4FA"
                                        Background="#2A2A3C" BorderThickness="0" Padding="6,3"
                                        Click="ImportStyles_Click"/>
                                <ListBox x:Name="StyleList" Background="Transparent" BorderThickness="0"
                                         Foreground="#A6ADC8" FontSize="11" Height="150" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 中栏：标签式编辑区 -->
            <Border Grid.Column="1" Background="#1E1E2E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 标签栏 -->
                    <TabControl x:Name="EditorTabs" Grid.Row="0" Background="#181825"
                                BorderBrush="#313244" BorderThickness="0,0,0,1" Height="32"
                                SelectionChanged="TabChanged"/>

                    <!-- 内容区 -->
                    <Grid Grid.Row="1">
                        <!-- 默认欢迎页 -->
                        <StackPanel x:Name="WelcomePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="NovelWriter" FontSize="28" FontWeight="Bold"
                                       Foreground="#89B4FA" HorizontalAlignment="Center"/>
                            <TextBlock Text="AI 网文写作助手" FontSize="16"
                                       Foreground="#6C7086" HorizontalAlignment="Center" Margin="0,8,0,20"/>
                            <Button Content="新建项目" Click="NewProject_Click" Width="160" Height="36"
                                    Foreground="#1E1E2E" Background="#A6E3A1"
                                    BorderThickness="0" FontSize="14" HorizontalAlignment="Center"/>
                            <Button Content="打开项目" Click="OpenProject_Click" Width="160" Height="36"
                                    Foreground="#89B4FA" Background="#313244"
                                    BorderThickness="0" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- 编辑器 -->
                        <TextBox x:Name="ContentEditor" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Foreground="#CDD6F4" Background="#1E1E2E"
                                 BorderThickness="0" Padding="16" FontSize="14"
                                 FontFamily="Consolas, Microsoft YaHei" Visibility="Collapsed"
                                 TextChanged="ContentEditor_Changed"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 右栏：AI 面板 -->
            <Border Grid.Column="2" Background="#11111B" BorderBrush="#313244" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- === 顶部：进度行 + 操作按钮 === -->
                    <Border Grid.Row="0" Background="#181825" Padding="10,7" BorderBrush="#313244" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ProgressText" Text="等待开始" Foreground="#A6ADC8"
                                       FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                       FontWeight="Medium"/>
                            <StackPanel x:Name="StageActions" Grid.Column="1" Orientation="Horizontal"
                                        Visibility="Collapsed">
                                <Button x:Name="StartAiBtn" Content="▶ 开始" Height="26"
                                        Foreground="#1E1E2E" Background="#89B4FA" BorderThickness="0" FontSize="11"
                                        Click="StartAiBtn_Click" Visibility="Collapsed" Margin="0,0,4,0"/>
                                <Button x:Name="ConfirmBtn" Content="✓ 确认" Width="56" Height="24"
                                        Foreground="#1E1E2E" Background="#A6E3A1" BorderThickness="0" FontSize="10"
                                        Click="StageConfirm_Click" Visibility="Collapsed" Margin="0,0,4,0"/>
                                <Button x:Name="RewriteBtn" Content="↻ 重写" Width="56" Height="24"
                                        Foreground="#1E1E2E" Background="#FAB387" BorderThickness="0" FontSize="10"
                                        Click="StageRewrite_Click" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- === 中部：主体区（待确认预览 + 聊天 + 思考状态） === -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 待确认预览面板：当前 Stage 的生成结果，确认后才会持久化到文件 -->
                        <Border x:Name="PreviewPanel" Grid.Row="0" Background="#1A1A2E"
                                BorderBrush="#45475A" BorderThickness="0,0,0,1"
                                Visibility="Collapsed" MaxHeight="280">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="#313244" Padding="8,4">
                                    <TextBlock x:Name="PreviewTitle" Text="— 待确认 —"
                                               Foreground="#FAB387" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                                <ScrollViewer x:Name="PreviewScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              Padding="0" Background="#1A1A2E">
                                    <TextBox x:Name="PreviewBody" Text="" Foreground="#CDD6F4"
                                             FontSize="12" Background="Transparent" BorderThickness="0"
                                             IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                             Padding="10,8" FontFamily="Consolas, Microsoft YaHei"
                                             VerticalScrollBarVisibility="Disabled"
                                             HorizontalScrollBarVisibility="Disabled"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- 聊天内容 -->
                        <ScrollViewer x:Name="ChatScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#11111B">
                            <ItemsControl x:Name="ChatList" Margin="8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Bg}" Padding="8,6" Margin="0,0,0,4" CornerRadius="4">
                                            <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{Binding Fg}"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- LLM 思考/编辑状态条 —— AI 工作中显示，停止按钮也在此 -->
                        <Border x:Name="ThinkingBar" Grid.Row="2" Background="#1A1A2E"
                                Padding="10,6" BorderBrush="#45475A" BorderThickness="0,1,0,0"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#89B4FA" CornerRadius="2" Width="4" Height="14"
                                        VerticalAlignment="Center" Margin="0,0,8,0"
                                        x:Name="ThinkingDot">
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="ThinkingDot"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.2" Duration="0:0:0.8"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                                <TextBlock x:Name="ThinkingText" Grid.Column="1" Text="AI 思考中..."
                                           Foreground="#89B4FA" FontSize="11" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- 停止按钮：始终跟随 ThinkingBar 一起出现/隐藏。
                                     "AI 在做什么"和"能不能停"应该放一起，用户一眼看到。 -->
                                <Button x:Name="StopBtn" Grid.Column="2" Content="■ 停止" Height="24"
                                        Foreground="#F38BA8" Background="#3C1A1A" BorderThickness="0"
                                        FontSize="10" Padding="10,0" Margin="8,0,0,0"
                                        Click="StopAi_Click" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- === 底部：对话输入区 === -->
                    <Border Grid.Row="2" Background="#181825" Padding="6" BorderBrush="#313244" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBox x:Name="ChatInput" AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="50" MaxHeight="120"
                                     Foreground="#CDD6F4" Background="#2A2A3C" BorderBrush="#45475A"
                                     Padding="6" FontSize="11" VerticalScrollBarVisibility="Auto"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="LlmNameText" Text="未配置 LLM" Foreground="#89B4FA" FontSize="11" VerticalAlignment="Center"/>
                                    <Button x:Name="LlmArrowBtn" Content="▼" FontSize="8" Foreground="#6C7086"
                                            Background="Transparent" BorderThickness="0" Padding="4,0"
                                            Click="LlmConfig_Click" Cursor="Hand" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- 上下文按钮：单击弹出会话上下文面板，显示使用百分比 + 压缩/归档 -->
                                <Button Grid.Column="1" x:Name="ContextBtn" Content="📊 上下文" Height="22" Margin="0,0,8,0"
                                        Foreground="#A6ADC8" Background="Transparent" BorderBrush="#45475A" FontSize="10"
                                        Click="ContextBtn_Click" Padding="10,0" Cursor="Hand" ToolTip="会话上下文使用率 + 压缩/归档入口"/>
                                <Button Grid.Column="2" Content="发送 ↵" Height="26"
                                        Foreground="#89B4FA" Background="#313244" BorderThickness="0" FontSize="10"
                                        Click="ChatSend_Click" Padding="12,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- === 状态栏 === -->
        <Border Grid.Row="2" Background="#11111B" Padding="8,3" BorderBrush="#313244" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBarText" Text="就绪" Foreground="#6C7086" FontSize="11"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- LLM 配置弹出面板 -->
        <Popup x:Name="LlmPopup" PlacementTarget="{Binding ElementName=LlmArrowBtn}" Placement="Top"
               StaysOpen="False" AllowsTransparency="True">
            <Border Background="#181825" BorderBrush="#45475A" BorderThickness="1" CornerRadius="4" Padding="12" Width="280">
                <StackPanel>
                    <TextBlock Text="LLM 配置" FontSize="12" FontWeight="SemiBold" Foreground="#89B4FA" Margin="0,0,0,8"/>
                    <TextBlock Text="API Key" Foreground="#6C7086" FontSize="10" Margin="0,0,0,2"/>
                    <TextBox x:Name="ApiKeyBox" Height="22" FontSize="10"
                             Foreground="#CDD6F4" Background="#2A2A3C" BorderBrush="#45475A" Padding="4"/>
                <TextBlock Text="模型" Foreground="#6C7086" FontSize="10" Margin="0,6,0,2"/>
                <TextBox x:Name="ModelBox" Height="22" FontSize="10"
                         Foreground="#CDD6F4" Background="#2A2A3C" BorderBrush="#45475A" Padding="4"/>
                <TextBlock Text="API 端点 (完整 URL)" Foreground="#6C7086" FontSize="10" Margin="0,6,0,2"/>
                <TextBox x:Name="UriBox" Height="22" FontSize="10"
                         Foreground="#CDD6F4" Background="#2A2A3C" BorderBrush="#45475A" Padding="4"/>
                    <Button Content="保存并连接" Height="26" Margin="0,8,0,0" FontSize="10"
                            Foreground="#A6E3A1" Background="#313244" BorderThickness="0"
                            Click="SaveLlmConfig_Click"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- 会话上下文弹出面板：显示使用率 + 压缩/归档按钮 -->
        <Popup x:Name="ContextPopup" PlacementTarget="{Binding ElementName=ContextBtn}" Placement="Top"
               StaysOpen="False" AllowsTransparency="True">
            <Border Background="#181825" BorderBrush="#45475A" BorderThickness="1" CornerRadius="4" Padding="14" Width="320">
                <StackPanel>
                    <TextBlock Text="📚 会话上下文" FontSize="12" FontWeight="SemiBold" Foreground="#89B4FA" Margin="0,0,0,8"/>

                    <!-- 使用率进度条 -->
                    <TextBlock x:Name="ContextUsageText" Text="—" Foreground="#CDD6F4" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#2A2A3C" Height="8" CornerRadius="2" Margin="0,0,0,8">
                        <Border x:Name="ContextUsageBar" Background="#A6E3A1" Height="8" CornerRadius="2"
                                HorizontalAlignment="Left" Width="0"/>
                    </Border>

                    <!-- 短期/长期事件统计 -->
                    <TextBlock x:Name="ContextStatsText" Text="—" Foreground="#A6ADC8" FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <!-- 操作按钮 -->
                    <Button x:Name="CompressPopupBtn" Content="🗜 压缩早期事件" Height="26" Margin="0,0,0,4" FontSize="10"
                            Foreground="#89B4FA" Background="#313244" BorderThickness="0"
                            Click="CompressSession_Click" ToolTip="用 LLM 压缩早期事件为摘要，保留最近 10 条原文"/>
                    <Button x:Name="ArchivePopupBtn" Content="📦 归档并清空短期" Height="26" FontSize="10"
                            Foreground="#FAB387" Background="#313244" BorderThickness="0"
                            Click="ArchiveToLongTerm_Click" ToolTip="把短期记忆归档到长期并清空短期"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
