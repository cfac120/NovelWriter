<Window x:Class="NovelWriter.App.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NovelWriter.App.ViewModels"
        xmlns:views="clr-namespace:NovelWriter.App.Views"
        Title="NovelWriter"
        Height="720" Width="1280"
        MinHeight="480" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.DataContext>
        <vm:ShellViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- 左栏 -->
            <Border Grid.Column="0" Background="#1A1A2E">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="NovelWriter" FontSize="18" FontWeight="Bold"
                                   Foreground="#89B4FA" Margin="0,8,0,16"/>
                        <ContentControl Content="{Binding ActiveView}">
                            <ContentControl.Resources>
                                <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
                                    <views:ProjectListView/>
                                </DataTemplate>
                            </ContentControl.Resources>
                        </ContentControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 中栏 -->
            <Border Grid.Column="1" Background="#1E1E2E">
                <TextBlock Text="选择或创建项目开始写作"
                           Foreground="#6C7086" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 右栏 -->
            <Border Grid.Column="2" Background="#181825">
                <StackPanel Margin="12">
                    <TextBlock Text="信息面板" FontSize="14" Foreground="#A6ADC8"/>
                    <TextBlock Text="暂无内容" Foreground="Gray" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="1" Background="#11111B" Height="28">
            <Grid Margin="8,0">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#A6ADC8"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right">
                    <TextBlock FontSize="12">
                        <Run Text="项目:" Foreground="#6C7086"/>
                        <Run Text="{Binding ProjectCount}" Foreground="#89B4FA"/>
                        <Run Text=" 字数:" Foreground="#6C7086"/>
                        <Run Text="{Binding TotalWordCount}" Foreground="#89B4FA"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
