<UserControl x:Class="NovelWriter.App.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NovelWriter.App.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#181825" Padding="12,8">
            <Grid>
                <TextBlock Text="{Binding ChapterTitle}" FontSize="16" FontWeight="Bold"
                           Foreground="#CDD6F4" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Foreground="#6C7086" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Run Text="字数:"/><Run Text="{Binding WordCount}" Foreground="#A6ADC8"/>
                    </TextBlock>
                    <TextBlock Foreground="#6C7086" VerticalAlignment="Center">
                        <Run Text="位置:"/><Run Text="{Binding CursorPosition}" Foreground="#A6ADC8"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 编辑器区域 -->
        <Border Grid.Row="1" Background="#1E1E2E">
            <TextBox x:Name="EditorTextBox"
                     Text="{Binding ChapterContent, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" AcceptsTab="True"
                     TextWrapping="Wrap"
                     Foreground="#CDD6F4" Background="Transparent"
                     BorderThickness="0" Margin="12"
                     FontFamily="Consolas, Microsoft YaHei" FontSize="15"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </Border>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Background="#181825" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="保存 (Ctrl+S)" Command="{Binding SaveCommand}"
                        Foreground="#A6E3A1" Background="#313244"
                        BorderThickness="0" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="AI 生成" Command="{Binding GenerateChapterCommand}"
                        Foreground="#89B4FA" Background="#313244"
                        BorderThickness="0" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="停止" Command="{Binding StopGenerationCommand}"
                        Foreground="#F38BA8" Background="#313244"
                        BorderThickness="0" Padding="12,4"/>
                <TextBlock Text="{Binding StatusText}" Foreground="#A6ADC8"
                           VerticalAlignment="Center" Margin="12,0,0,0" FontSize="11"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
