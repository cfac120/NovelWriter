<Window x:Class="NovelWriter.App.Views.OpenProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="打开项目" Height="400" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E" ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="打开项目" FontSize="18" FontWeight="Bold"
                   Foreground="#89B4FA" Margin="0,0,0,8"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="已发现的项目:" Foreground="#A6ADC8" FontSize="12" VerticalAlignment="Center"/>
            <Button Content="浏览文件夹..." Click="BrowseFolder_Click" Margin="12,0,0,0"
                    Foreground="#89B4FA" Background="#2A2A3C" BorderThickness="0"
                    Padding="8,3" FontSize="11" HorizontalAlignment="Right"/>
        </StackPanel>

        <ListBox x:Name="ProjectList" Grid.Row="2" Background="#181825"
                 BorderBrush="#313244" Foreground="#CDD6F4"
                 SelectionMode="Single" MouseDoubleClick="ProjectList_DoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" BorderBrush="#313244" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="13" Foreground="#CDD6F4"/>
                            <TextBlock FontSize="10">
                                <Run Text="{Binding Phase}" Foreground="#89B4FA"/>
                                <Run Text=" · " Foreground="#6C7086"/>
                                <Run Text="{Binding Path}" Foreground="#585B70"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#F38BA8" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="取消" Click="Cancel_Click" IsCancel="True"
                    Foreground="#6C7086" Background="#313244" BorderThickness="0" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="打开" Click="Open_Click" IsDefault="True"
                    Foreground="#A6E3A1" Background="#313244" BorderThickness="0" Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
