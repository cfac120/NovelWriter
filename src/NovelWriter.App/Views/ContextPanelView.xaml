<UserControl x:Class="NovelWriter.App.Views.ContextPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <TextBlock Text="上下文面板" FontSize="14" FontWeight="SemiBold"
                           Foreground="#A6ADC8" Margin="0,0,0,12"/>

                <Expander Header="L1 最近章节摘要" IsExpanded="True"
                          Foreground="#89B4FA" Background="#2A2A3C" Margin="0,0,0,8">
                    <ItemsControl x:Name="L1List" Margin="8,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#313244" Padding="8,6" Margin="0,0,0,4" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="#CDD6F4" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Summary}" Foreground="#A6ADC8" FontSize="11"
                                                   TextWrapping="Wrap" MaxHeight="80" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <Expander Header="L2 活跃伏笔与弧线" IsExpanded="True"
                          Foreground="#89B4FA" Background="#2A2A3C" Margin="0,0,0,8">
                    <StackPanel Margin="8,4">
                        <TextBlock x:Name="L2Foreshadowings" Text="暂无活跃伏笔" Foreground="#6C7086" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="L2Arcs" Text="" Foreground="#6C7086" FontSize="11" Margin="0,0,0,4"/>
                        <TextBlock x:Name="L2Subplots" Text="" Foreground="#6C7086" FontSize="11"/>
                    </StackPanel>
                </Expander>

                <Expander Header="L3 人物档案与世界观" IsExpanded="True"
                          Foreground="#89B4FA" Background="#2A2A3C" Margin="0,0,0,8">
                    <ItemsControl x:Name="L3List" Margin="8,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#313244" Padding="8,6" Margin="0,0,0,4" CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="#F5C2E7" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Detail}" Foreground="#A6ADC8" FontSize="11"
                                                   TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <Border Background="#2A2A3C" Padding="8" CornerRadius="4" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Token 预算" Foreground="#A6ADC8" FontSize="11" Margin="0,0,0,4"/>
                        <ProgressBar x:Name="TokenBar" Height="6" Minimum="0" Maximum="160000"
                                     Foreground="#A6E3A1" Background="#313244"/>
                        <TextBlock x:Name="TokenDetail" Text="0 / 160,000" Foreground="#6C7086" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
